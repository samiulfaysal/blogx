{{!-- ==========================================
     BlogX Theme - Tag Archive Template
     Design: Technical, Sharp, Tactical
     ========================================== --}}
{{!< default}}

{{!-- Tag Hero --}}
<section class="hero fade-in" style="min-height: 50vh; padding: calc(var(--space-32) + 60px) 0 var(--space-16);">
    <div class="hero__content container">
        <div class="hero__terminal" style="margin-bottom: var(--space-6);">
            <span class="hero__terminal-dot"></span>
            <span>TOPIC</span>
        </div>
        <h1 class="hero__title">{{tag.name}}</h1>
        {{#if tag.description}}
        <p class="hero__subtitle">{{tag.description}}</p>
        {{/if}}
        <p style="margin-top: var(--space-4); color: var(--color-text-muted); font-family: var(--font-mono); font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.08em;">
            {{plural pagination.total empty="No articles" singular="% article" plural="% articles"}}
        </p>
    </div>
</section>

{{!-- Articles Grid --}}
<section class="section" style="padding-top: var(--space-8);">
    <div class="container">
        {{#if posts}}
        <div class="grid grid--3">
            {{#foreach posts}}
            <article class="card" data-tilt>
                {{#if feature_image}}
                <div class="card__image">
                    <img src="{{feature_image}}" alt="{{title}}" loading="lazy" width="640" height="360">
                </div>
                {{/if}}
                <div class="card__content">
                    <div class="card__meta">
                        {{#primary_tag}}
                        <span class="card__tag">{{name}}</span>
                        {{/primary_tag}}
                        <span class="card__date">{{reading_time}}</span>
                    </div>
                    <h3 class="card__title">
                        <a href="{{url}}">{{title}}</a>
                    </h3>
                    <p class="card__excerpt">{{excerpt}}</p>
                    <div class="card__footer">
                        <div class="card__author">
                            {{#if primary_author.profile_image}}
                            <img class="card__author-avatar" src="{{primary_author.profile_image}}" alt="{{primary_author.name}}" width="24" height="24">
                            {{else}}
                            <div class="card__author-avatar" style="display: flex; align-items: center; justify-content: center; font-weight: 600; font-size: var(--text-xs); color: var(--color-bg-primary);">
                                {{primary_author.initial}}
                            </div>
                            {{/if}}
                            <span class="card__author-name">{{primary_author.name}}</span>
                        </div>
                        <a href="{{url}}" class="article__share" aria-label="Read {{title}}" style="margin-top: 0;">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M5 12h14M12 5l7 7-7 7"/>
                            </svg>
                        </a>
                    </div>
                </div>
            </article>
            {{/foreach}}
        </div>

        {{pagination}}
        {{else}}
        <div class="empty-state">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
                <line x1="7" y1="7" x2="7.01" y2="7"></line>
            </svg>
            <h3>No articles found</h3>
            <p>No articles have been published with this topic yet.</p>
            <a href="{{@site.url}}/blog" class="btn btn--secondary" style="margin-top: var(--space-6);">
                Browse all articles
            </a>
        </div>
        {{/if}}
    </div>
</section>

{{> newsletter-cta}}