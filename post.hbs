{{!-- ==========================================
     BlogX Theme - Single Post Template
     Design: Technical Editorial, Terminal-style
     ========================================== --}}
{{!< default}}

{{#post}}

{{!-- Post-specific SEO --}}
<meta property="og:type" content="article">
<meta property="article:published_time" content="{{published_at}}">
{{#if primary_author}}<meta property="article:author" content="{{primary_author.name}}">{{/if}}
{{#primary_tag}}<meta property="article:tag" content="{{name}}">{{/primary_tag}}

<article class="article">
    {{!-- Terminal Metadata Bar --}}

    {{!-- Article Header --}}
    <header class="article__header">
        <h1 class="article__title fade-in-up stagger-1">{{title}}</h1>

        {{#if excerpt}}
        <p class="article__excerpt fade-in-up stagger-2">{{excerpt}}</p>
        {{/if}}

        {{!-- Author Info --}}
<div class="article__meta fade-in-up stagger-3">
            {{!-- 1. Tag --}}
            {{#primary_tag}}
            <div class="article__meta-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
                    <line x1="7" y1="7" x2="7.01" y2="7"></line>
                </svg>
                <a href="{{url}}" style="color: var(--color-accent-primary); border: none;">{{name}}</a>
            </div>
            {{/primary_tag}}

            {{!-- 2. Author --}}
            {{#if primary_author}}
            <a href="{{primary_author.url}}" class="article__meta-item article__meta-item--link">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                    <circle cx="12" cy="7" r="4"></circle>
                </svg>
                {{primary_author.name}}
            </a>
            {{/if}}

            {{!-- 3. Date --}}
            <div class="article__meta-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polyline points="12 6 12 12 16 14"></polyline>
                </svg>
                {{#if published_at}}{{date published_at format="MMMM D, YYYY"}}{{/if}}
            </div>

            {{!-- 4. Reading Time --}}
            <div class="article__meta-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                    <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
                </svg>
                {{reading_time}}
            </div>
        </div>
    </header>

    {{!-- Cover Image --}}
    {{#if feature_image}}
    <div class="article__cover fade-in-up stagger-2">
        <img src="{{feature_image}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}" {{#if feature_image_caption}}title="{{feature_image_caption}}"{{/if}} width="1200" height="675" loading="eager">
    </div>
    {{#if feature_image_caption}}
    <p class="article__cover-caption">{{feature_image_caption}}</p>
    {{/if}}
    {{/if}}

    {{!-- Article Content --}}
    <div class="article__content">
        {{content}}
    </div>

    {{!-- Post Footer --}}
    <footer class="article__footer fade-in-up">
        {{!-- Tags --}}
        {{#if tags}}
        <div class="article__tags">
            <span class="article__tags-label">Tagged:</span>
            {{#foreach tags}}
            <a href="{{url}}" class="article__tag">{{name}}</a>
            {{/foreach}}
        </div>
        {{/if}}

        {{!-- Share Buttons --}}
        <div class="article__share">
            <span class="article__share-label">Share</span>
            <a href="https://twitter.com/intent/tweet?url={{url absolute="true"}}&text={{title}}" target="_blank" rel="noopener noreferrer" aria-label="Share on Twitter">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
            </a>
            <a href="https://www.linkedin.com/shareArticle?mini=true&url={{url absolute="true"}}&title={{title}}" target="_blank" rel="noopener noreferrer" aria-label="Share on LinkedIn">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
            </a>
            <button onclick="navigator.clipboard.writeText(window.location.href)" aria-label="Copy link" data-copy-link>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
                    <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
                </svg>
            </button>
        </div>
    </footer>

    {{!-- Author Bio Card --}}
    {{#if primary_author}}
    <div class="article__author fade-in-up">
        <div class="article__author-card">
            {{#if primary_author.profile_image}}
            <img class="article__author-avatar" src="{{primary_author.profile_image}}" alt="{{primary_author.name}}" width="64" height="64">
            {{else}}
            <div class="article__author-avatar article__author-avatar--placeholder" style="width: 64px; height: 64px; display: flex; align-items: center; justify-content: center; font-weight: 600; color: var(--color-bg-primary);">
                {{primary_author.initial}}
            </div>
            {{/if}}
            <div class="article__author-info">
                <span class="article__author-label">Written by</span>
                <h4 class="article__author-name">
                    {{#if primary_author.url}}
                    <a href="{{primary_author.url}}">{{primary_author.name}}</a>
                    {{else}}
                    {{primary_author.name}}
                    {{/if}}
                </h4>
                {{#if primary_author.bio}}
                <p class="article__author-bio">{{primary_author.bio}}</p>
                {{/if}}
            </div>
        </div>
    </div>
    {{/if}}
</article>

{{/post}}

{{!-- Related Posts (via get query) --}}
{{#if primary_tag}}
{{#get "posts" filter="tags:[{{primary_tag.slug}}]+id:-{{id}}" limit="3" include="authors,tags" as |related|}}
{{#if related}}
<section class="section">
    <div class="container">
        <header class="section-header">
            <span class="section-header__eyebrow">Continue Reading</span>
            <h2 class="section-header__title">Related Transmissions</h2>
        </header>

        <div class="grid grid--3">
            {{#foreach related}}
            <article class="card" data-tilt>
                {{#if feature_image}}
                <div class="card__image">
                    <img src="{{feature_image}}" alt="{{title}}" loading="lazy" width="640" height="360">
                </div>
                {{/if}}
                <div class="card__content">
                    <div class="card__meta">
                        {{#primary_tag}}
                        <span class="card__tag">{{name}}</span>
                        {{/primary_tag}}
                        <span class="card__date">{{reading_time}}</span>
                    </div>
                    <h3 class="card__title">
                        <a href="{{url}}">{{title}}</a>
                    </h3>
                    <p class="card__excerpt">{{excerpt}}</p>
                </div>
            </article>
            {{/foreach}}
        </div>
    </div>
</section>
{{/if}}
{{/get}}
{{/if}}

{{> newsletter-cta}}