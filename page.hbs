{{!-- ==========================================
     BlogX Theme - Static Page Template
     Design: Technical Editorial, Terminal-style
     ========================================== --}}
{{!< default}}

{{#post}}

<article class="article {{#if feature_image}}has-feature-image{{/if}} {{#if page}}is-page{{/if}} {{post_class}}">
    {{!-- Page Header --}}
    <header class="article__header">
        {{#if @page.show_title_and_feature_image}}
        <h1 class="article__title fade-in-up">{{title}}</h1>

        {{#if custom_excerpt}}
        <p class="article__excerpt fade-in-up stagger-1">{{custom_excerpt}}</p>
        {{else}}
        {{#if excerpt}}
        <p class="article__excerpt fade-in-up stagger-1">{{excerpt}}</p>
        {{/if}}
        {{/if}}

        {{else}}
        <h1 class="sr-only">{{title}}</h1>
        {{/if}}

        {{!-- Page Meta --}}
        <div class="article__meta fade-in-up stagger-2">
            <div class="article__meta-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polyline points="12 6 12 12 16 14"></polyline>
                </svg>
                {{#if published_at}}{{date published_at format="MMMM D, YYYY"}}{{else if created_at}}{{date created_at format="MMMM D, YYYY"}}{{else}}{{date format="MMMM D, YYYY"}}{{/if}}
            </div>
            {{#if primary_author}}
            <div class="article__meta-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                    <circle cx="12" cy="7" r="4"></circle>
                </svg>
                {{primary_author.name}}
            </div>
            {{/if}}
        </div>
    </header>

    {{!-- Feature Image (only if page builder shows it) --}}
    {{#if @page.show_title_and_feature_image}}
    {{#if feature_image}}
    <div class="article__cover fade-in-up stagger-2">
        <img src="{{feature_image}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}" {{#if feature_image_caption}}title="{{feature_image_caption}}"{{/if}} width="1200" height="675">
    </div>
    {{/if}}
    {{#if feature_image_caption}}
    <p class="article__cover-caption">{{feature_image_caption}}</p>
    {{/if}}
    {{/if}}

    {{!-- Page Content --}}
    <div class="article__content">
        {{content}}
    </div>

    {{!-- Tags --}}
    {{#if tags}}
    <div class="article__tags fade-in-up">
        <span class="article__tags-label">Tags:</span>
        {{#foreach tags}}
        <a href="{{url}}" class="article__tag">{{name}}</a>
        {{/foreach}}
    </div>
    {{/if}}

    {{!-- Author Bio Card --}}
    {{#if primary_author}}
    <div class="article__author fade-in-up">
        <div class="article__author-card">
            {{#if primary_author.profile_image}}
            <img class="article__author-avatar" src="{{primary_author.profile_image}}" alt="{{primary_author.name}}" width="64" height="64">
            {{else}}
            <div class="article__author-avatar article__author-avatar--placeholder" style="width: 64px; height: 64px; display: flex; align-items: center; justify-content: center; font-weight: 600; color: var(--color-bg-primary);">
                {{primary_author.initial}}
            </div>
            {{/if}}
            <div class="article__author-info">
                <span class="article__author-label">Written by</span>
                <h4 class="article__author-name">{{primary_author.name}}</h4>
                {{#if primary_author.bio}}
                <p class="article__author-bio">{{primary_author.bio}}</p>
                {{/if}}
                {{#if primary_author.url}}
                <a href="{{primary_author.url}}" class="article__author-link" target="_blank" rel="noopener">
                    View all posts
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                        <polyline points="15 3 21 3 21 9"></polyline>
                        <line x1="10" y1="14" x2="21" y2="3"></line>
                    </svg>
                </a>
                {{/if}}
            </div>
        </div>
    </div>
    {{/if}}
</article>

{{/post}}

{{> newsletter-cta}}