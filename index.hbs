{{!-- ==========================================
     BlogX Theme - Homepage
     Codorax Brand - Split-Hero Architecture
     ========================================== --}}
{{!< default}}

{{!-- Split-Hero Section --}}
<section class="split-hero">
    <div class="container">
        <div class="split-hero__grid">
            {{!-- LEFT SIDE: Primary Feature (Post #1) --}}
            {{#foreach posts limit="1"}}
            <article class="split-hero__primary">
                {{#if feature_image}}
                <a href="{{url}}" class="split-hero__image">
                    <img src="{{feature_image}}" alt="{{title}}" width="800" height="450" loading="eager">
                </a>
                {{/if}}
                <div class="split-hero__content">
                    {{#primary_tag}}
                    <span class="split-hero__tag">{{name}}</span>
                    {{/primary_tag}}
                    <h1 class="split-hero__title">
                        <a href="{{url}}">{{title}}</a>
                    </h1>
                    <p class="split-hero__excerpt">{{excerpt}}</p>
                    <div class="split-hero__meta">
                        {{#if primary_author.profile_image}}
                        <img class="split-hero__author-avatar" src="{{primary_author.profile_image}}" alt="{{primary_author.name}}" width="28" height="28">
                        {{else}}
                        <span class="split-hero__author-avatar split-hero__author-avatar--placeholder"></span>
                        {{/if}}
                        <span class="split-hero__author-name">{{primary_author.name}}</span>
                        <span class="split-hero__divider">/</span>
                        <span class="split-hero__date">{{reading_time}}</span>
                    </div>
                </div>
            </article>
            {{/foreach}}

            {{!-- RIGHT SIDE: Secondary Stack (Posts #2-4) --}}
            <div class="split-hero__secondary">
                {{#foreach posts from="2" limit="3"}}
                <article class="split-hero__item">
                    {{#if feature_image}}
                    <a href="{{url}}" class="split-hero__item-image">
                        <img src="{{feature_image}}" alt="{{title}}" width="80" height="80" loading="lazy">
                    </a>
                    {{/if}}
                    <div class="split-hero__item-content">
                        <h3 class="split-hero__item-title">
                            <a href="{{url}}">{{title}}</a>
                        </h3>
                        <span class="split-hero__item-date">{{reading_time}}</span>
                    </div>
                </article>
                {{/foreach}}
            </div>
        </div>
    </div>
</section>

{{!-- Discovery Row --}}
<section class="discovery-row">
    <div class="container">
        <div class="discovery-row__grid">
            {{!-- A) Brand DNA Box --}}
            <div class="discovery-row__brand">
                <div class="brand-dna">
                    <div class="brand-dna__icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                            <path d="M2 17l10 5 10-5"/>
                            <path d="M2 12l10 5 10-5"/>
                        </svg>
                    </div>
                    <h3 class="brand-dna__title">{{@site.title}}</h3>
                    <p class="brand-dna__mission">Engineering complex infrastructure into beautifully simple digital experiences.</p>
                    <div class="brand-dna__social">
                        <a href="https://github.com/codorax" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
                            </svg>
                        </a>
                        <a href="https://twitter.com/codorax" target="_blank" rel="noopener noreferrer" aria-label="Twitter">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                            </svg>
                        </a>
                        <a href="https://linkedin.com/company/codorax" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                            </svg>
                        </a>
                    </div>
                </div>
            </div>

            {{!-- B) Featured List --}}
            <div class="discovery-row__featured">
                <h4 class="discovery-row__heading">Featured</h4>
                <ul class="featured-list">
                    {{#get "posts" limit="5"}}
                        {{#foreach posts}}
                        <li class="featured-list__item">
                            {{#if feature_image}}
                            <a href="{{url}}" class="featured-list__image">
                                <img src="{{feature_image}}" alt="{{title}}" width="48" height="48" loading="lazy">
                            </a>
                            {{/if}}
                            <a href="{{url}}" class="featured-list__title">{{title}}</a>
                        </li>
                        {{/foreach}}
                    {{/get}}
                </ul>
            </div>

            {{!-- C) Tag Cloud --}}
            <div class="discovery-row__tags">
                <h4 class="discovery-row__heading">Topics</h4>
                <div class="tag-cloud">
                    {{#get "tags" limit="12"}}
                        {{#foreach tags}}
                        <a href="{{url}}" class="tag-cloud__item">{{name}}</a>
                        {{/foreach}}
                    {{/get}}
                </div>
            </div>
        </div>
    </div>
</section>

{{!-- Main Feed - Modular Grid (Posts #5+) --}}
<section class="main-feed" id="posts">
    <div class="container">
        <header class="section-header fade-in-up">
            <span class="section-header__eyebrow">Latest Transmissions</span>
            <h2 class="section-header__title">Engineering Intel</h2>
        </header>

        {{#if posts}}
        <div class="grid grid--2 main-feed__grid">
            {{#foreach posts from="5"}}
            <article class="card article-card" data-tilt>
                {{#if feature_image}}
                <div class="card__image">
                    <img src="{{feature_image}}" alt="{{title}}" loading="lazy" width="640" height="360">
                </div>
                {{/if}}
                <div class="card__content">
                    <div class="card__meta">
                        {{#primary_tag}}
                        <span class="card__tag">{{name}}</span>
                        {{/primary_tag}}
                        <span class="card__date">{{reading_time}}</span>
                    </div>
                    <h3 class="card__title">
                        <a href="{{url}}">{{title}}</a>
                    </h3>
                    <p class="card__excerpt">{{excerpt}}</p>
                    <div class="card__footer">
                        <div class="card__author">
                            {{#if primary_author.profile_image}}
                            <img class="card__author-avatar" src="{{primary_author.profile_image}}" alt="{{primary_author.name}}" width="24" height="24">
                            {{else}}
                            <div class="card__author-avatar"></div>
                            {{/if}}
                            <span class="card__author-name">{{primary_author.name}}</span>
                        </div>
                        <span class="card__timestamp">{{reading_time}}</span>
                    </div>
                </div>
            </article>
            {{/foreach}}
        </div>
        {{else}}
        <div style="text-align: center; padding: var(--space-16) 0;">
            <p style="color: var(--color-text-muted); font-family: var(--font-mono);">No transmissions yet. Check back soon.</p>
        </div>
        {{/if}}

        {{pagination}}
    </div>
</section>

{{!-- Newsletter CTA --}}
{{> newsletter-cta}}