{{!-- ==========================================
     BlogX Theme - Homepage
     Codorax Brand - Split-Hero Architecture
     ========================================== --}}
{{!< default}}

{{!-- Split-Hero Section --}}
<section class="split-hero">
    <div class="container">
        <div class="split-hero__grid">
            {{!-- LEFT SIDE: Primary Feature (Post #1) --}}
            {{#foreach posts limit="1"}}
            <article class="split-hero__primary">
                {{#if feature_image}}
                <a href="{{url}}" class="split-hero__image">
                    <img src="{{feature_image}}" alt="{{title}}" width="800" height="450" loading="eager">
                </a>
                {{/if}}
                <div class="split-hero__content">
                    {{#primary_tag}}
                    <span class="split-hero__tag">{{name}}</span>
                    {{/primary_tag}}
                    <h1 class="split-hero__title">
                        <a href="{{url}}">{{title}}</a>
                    </h1>
                    <p class="split-hero__excerpt">{{excerpt}}</p>
                    <div class="split-hero__meta">
                        {{#if primary_author.profile_image}}
                        <img class="split-hero__author-avatar" src="{{primary_author.profile_image}}" alt="{{primary_author.name}}" width="28" height="28">
                        {{else}}
                        <span class="split-hero__author-avatar split-hero__author-avatar--placeholder"></span>
                        {{/if}}
                        <span class="split-hero__author-name">{{primary_author.name}}</span>
                        <span class="split-hero__divider">/</span>
                        <span class="split-hero__date">{{reading_time}}</span>
                    </div>
                </div>
            </article>
            {{/foreach}}

            {{!-- RIGHT SIDE: Secondary Stack (Posts #2-4) --}}
            <div class="split-hero__secondary">
                {{#foreach posts from="2" limit="3"}}
                <article class="split-hero__item">
                    {{#if feature_image}}
                    <a href="{{url}}" class="split-hero__item-image">
                        <img src="{{feature_image}}" alt="{{title}}" width="80" height="80" loading="lazy">
                    </a>
                    {{/if}}
                    <div class="split-hero__item-content">
                        <h3 class="split-hero__item-title">
                            <a href="{{url}}">{{title}}</a>
                        </h3>
                        <span class="split-hero__item-date">{{reading_time}}</span>
                    </div>
                </article>
                {{/foreach}}
            </div>
        </div>
    </div>
</section>

{{!-- Main Feed - Modular Grid (Posts #5+) --}}
<section class="main-feed" id="posts">
    <div class="container">
        {{#if posts}}
        <div class="grid grid--2 main-feed__grid">
            {{#foreach posts from="5"}}
            <article class="card article-card" data-tilt>
                {{#if feature_image}}
                <div class="card__image">
                    <img src="{{feature_image}}" alt="{{title}}" loading="lazy" width="640" height="360">
                </div>
                {{/if}}
                <div class="card__content">
                    <div class="card__meta">
                        {{#primary_tag}}
                        <span class="card__tag">{{name}}</span>
                        {{/primary_tag}}
                        <span class="card__date">{{reading_time}}</span>
                    </div>
                    <h3 class="card__title">
                        <a href="{{url}}">{{title}}</a>
                    </h3>
                    <p class="card__excerpt">{{excerpt}}</p>
                    <div class="card__footer">
                        <div class="card__author">
                            {{#if primary_author.profile_image}}
                            <img class="card__author-avatar" src="{{primary_author.profile_image}}" alt="{{primary_author.name}}" width="24" height="24">
                            {{else}}
                            <div class="card__author-avatar"></div>
                            {{/if}}
                            <span class="card__author-name">{{primary_author.name}}</span>
                        </div>
                        <span class="card__timestamp">{{reading_time}}</span>
                    </div>
                </div>
            </article>
            {{/foreach}}
        </div>
        {{else}}
        <div style="text-align: center; padding: var(--space-16) 0;">
            <p style="color: var(--color-text-muted); font-family: var(--font-mono);">No transmissions yet. Check back soon.</p>
        </div>
        {{/if}}

        {{pagination}}
    </div>
</section>

{{!-- Discovery Row (now positioned as pre-footer) --}}
<section class="discovery-row">
    <div class="container">
        <div class="discovery-row__grid">
{{!-- A) Brand DNA Box --}}
            <div class="discovery-row__brand">
                <div class="brand-dna">
                    <div class="brand-dna__icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                            <path d="M2 17l10 5 10-5"/>
                            <path d="M2 12l10 5 10-5"/>
                        </svg>
                    </div>
                    <h3 class="brand-dna__title">{{@site.title}}</h3>
                    {{#if @custom.brand_mission}}
                    <p class="brand-dna__mission">{{@custom.brand_mission}}</p>
                    {{/if}}
                    <div class="brand-dna__social">
                        {{!-- Native Ghost Twitter --}}
                        {{#if @site.twitter}}
                        <a href="{{social_url type="twitter"}}" target="_blank" rel="noopener noreferrer" aria-label="Twitter">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                            </svg>
                        </a>
                        {{/if}}

                        {{!-- Native Ghost Facebook --}}
                        {{#if @site.facebook}}
                        <a href="{{social_url type="facebook"}}" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.469h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.469h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                            </svg>
                        </a>
                        {{/if}}
                    </div>
                </div>
            </div>
            {{!-- B) Featured List --}}
            <div class="discovery-row__featured">
                <h4 class="discovery-row__heading">Featured</h4>
                <ul class="featured-list">
                    {{#get "posts" limit="5"}}
                        {{#foreach posts}}
                        <li class="featured-list__item">
                            {{#if feature_image}}
                            <a href="{{url}}" class="featured-list__image">
                                <img src="{{feature_image}}" alt="{{title}}" width="48" height="48" loading="lazy">
                            </a>
                            {{/if}}
                            <a href="{{url}}" class="featured-list__title">{{title}}</a>
                        </li>
                        {{/foreach}}
                    {{/get}}
                </ul>
            </div>

            {{!-- C) Tag Cloud --}}
            <div class="discovery-row__tags">
                <h4 class="discovery-row__heading">Topics</h4>
                <div class="tag-cloud">
                    {{#get "tags" limit="12"}}
                        {{#foreach tags}}
                        <a href="{{url}}" class="tag-cloud__item">{{name}}</a>
                        {{/foreach}}
                    {{/get}}
                </div>
            </div>
        </div>
    </div>
</section>

{{!-- Newsletter CTA --}}
{{> newsletter-cta}}