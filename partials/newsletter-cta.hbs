{{!-- ==========================================
     BlogX Theme - Newsletter CTA
     Design: Terminal-style
     ========================================== --}}
<section class="section">
    <div class="container">
        <div class="newsletter fade-in-up">
            <div class="newsletter__content">
                <h2 class="newsletter__title">Stay Synchronized</h2>
                <p class="newsletter__description">
                    Get high-velocity insights on web development and architecture delivered to your terminal.
                </p>
                <form class="newsletter__form" data-members-form>
                    <input
                        type="email"
                        name="email"
                        class="newsletter__input"
                        placeholder="enter@email.com"
                        required
                        aria-label="Email address"
                    >
                    <button type="submit" class="btn btn--primary">
                        Subscribe
                    </button>
                </form>
                <p class="newsletter__disclaimer">
                    No spam. Unsubscribe anytime.
                </p>
            </div>
        </div>
    </div>
</section>