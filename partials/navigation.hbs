                    <svg width="28" height="28" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M16 4L28 10V22L16 28L4 22V10L16 4Z" stroke="url(#nav-gradient)" stroke-width="1.5" fill="none"/>
