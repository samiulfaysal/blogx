{{!-- ==========================================
     BlogX Theme - Footer (Codorax Brand)
     Design: 4-Column Technical
     ========================================== --}}
<footer class="footer" role="contentinfo">
    <div class="container">
        <div class="footer__grid">
            {{!-- Column 1: Company --}}
            <div class="footer__column">
                <h4>Company</h4>
                <ul class="footer__links">
                    <li><a href="{{@site.url}}/about">About</a></li>
                    <li><a href="{{@site.url}}/careers">Careers</a></li>
                    <li><a href="{{@site.url}}/services">Services</a></li>
                    <li><a href="{{@site.url}}/contact">Contact</a></li>
                </ul>
            </div>

            {{!-- Column 2: Resources --}}
            <div class="footer__column">
                <h4>Resources</h4>
                <ul class="footer__links">
                    <li><a href="{{@site.url}}/blog">Blog</a></li>
                    <li><a href="{{@site.url}}/tags">Topics</a></li>
                    <li><a href="https://docs.codorax.io" target="_blank" rel="noopener">Documentation</a></li>
                    <li><a href="{{@site.url}}/newsletter">Newsletter</a></li>
                </ul>
            </div>

{{!-- Column 3: Socials --}}
            <div class="footer__column">
                <h4>Socials</h4>
                <div class="footer__social">
                    
                    {{!-- Native Ghost Twitter --}}
                    {{#if @site.twitter}}
                    <a href="{{social_url type="twitter"}}" target="_blank" rel="noopener noreferrer" aria-label="Twitter">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                        </svg>
                    </a>
                    {{/if}}

                    {{!-- Native Ghost Facebook --}}
                    {{#if @site.facebook}}
                    <a href="{{social_url type="facebook"}}" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.469h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.469h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                        </svg>
                    </a>
                    {{/if}}
                    
                </div>
            </div>

            {{!-- Column 4: Newsletter --}}
            <div class="footer__column footer__column--newsletter">
                <h4>Subscribe</h4>
                <p class="footer__newsletter-text">Get the latest engineering insights delivered to your inbox.</p>
                <form class="footer__newsletter-form" data-members-form>
                    <input type="email" name="email" placeholder="email@domain.com" class="footer__newsletter-input" aria-label="Email address" required>
                    <button type="submit" class="footer__newsletter-btn" aria-label="Subscribe">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M5 12h14M12 5l7 7-7 7"/>
                        </svg>
                    </button>
                </form>
            </div>
        </div>

        <div class="footer__bottom">
            <p class="footer__copyright">
                &copy; {{date format="YYYY"}} {{@site.title}}. All rights reserved.
            </p>
            <div class="footer__legal">
                <a href="{{@site.url}}/privacy">Privacy</a>
                <a href="{{@site.url}}/terms">Terms</a>
                <a href="{{@site.url}}/sitemap.xml">Sitemap</a>
            </div>
        </div>
    </div>
</footer>